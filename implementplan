Chat: system prompt = "Answer ONLY from this document: {docText.slice(0,8000)}". Include last 5 messages as history.

Summary: prompt = "Create a comprehensive summary with: 1. Key Topics 2. Main Concepts 3. Important Details. Format with clear sections."

Explain: prompt = "Explain the concept '{topic}' from this document. Use simple language, analogies, and 3 practical examples."

Flashcards: prompt = "Generate {count} flashcards as JSON array ONLY: [{\"front\":\"question\",\"back\":\"answer\"}]. Cover the most important concepts."

Quiz: prompt = "Generate {count} MCQ questions as JSON array ONLY: [{\"question\":\"...\",\"options\":[\"A\",\"B\",\"C\",\"D\"],\"correct\":0,\"explanation\":\"...\"}]. Use correct:0-3 as index."

